# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Summarization (OpenAI-compatible API)
# Leave blank to disable summarization entirely.
# ---------------------------------------------------------------------------

# Base URL of the chat completions API (no trailing slash)
# Examples:
#   OpenAI:  https://api.openai.com/v1
#   Groq:    https://api.groq.com/openai/v1
#   Ollama:  http://localhost:11434/v1
SUMMARIZE_API_URL=

# API key / bearer token (use any non-empty string for Ollama)
SUMMARIZE_API_KEY=

# Model name to use for summarization
# Examples:
#   OpenAI:  gpt-4o-mini
#   Groq:    llama-3.3-70b-versatile
#   Ollama:  qwen2.5:3b
SUMMARIZE_MODEL=

# Optional: override the directory that holds summarize-*.md prompt files
# SUMMARIZE_PROMPTS_DIR=/path/to/custom/prompts

# ---------------------------------------------------------------------------
# Paths (optional overrides)
# ---------------------------------------------------------------------------

# Path to the SQLite database file
# CONTEXT_CACHE_DB_PATH=

# Root directory of the knowledge-base markdown files
# CONTEXT_CACHE_KB_PATH=

# ---------------------------------------------------------------------------
# Embedding (Ollama)
# ---------------------------------------------------------------------------

# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------------
# Search tuning
# ---------------------------------------------------------------------------

# CONTEXT_CACHE_SEARCH_LIMIT=10
# CONTEXT_CACHE_RRF_K=60
# CONTEXT_CACHE_CHUNK_SIZE=1000
# CONTEXT_CACHE_CHUNK_OVERLAP=200
